<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <!-- Bootstrap 5 -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <!-- AdminLTE 4 -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/admin-lte@4.0.0-beta2/dist/css/adminlte.min.css">
    <!-- GridStack CSS -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/gridstack.js/9.2.2/gridstack.min.css" rel="stylesheet"/>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/gridstack.js/9.2.2/gridstack-extra.min.css" rel="stylesheet"/>
    <style>
        .grid-stack { background: #f8f9fa; border: 2px dashed #dee2e6; min-height: 500px; border-radius: 8px; padding: 10px; }
        .grid-stack-item-content { background: white; border: 1px solid #ddd; box-shadow: 0 2px 5px rgba(0,0,0,0.05); border-radius: 4px; padding: 10px; display: flex; flex-direction: column;}
        .report-draggable { cursor: grab; background: #fff; border: 1px solid #ced4da; padding: 10px; margin-bottom: 8px; border-radius: 4px; transition: all 0.2s;}
        .report-draggable:hover { background: #e9ecef; border-color: #adb5bd; }
        .widget-header { display: flex; justify-content: space-between; align-items: center; border-bottom: 1px solid #eee; padding-bottom: 5px; margin-bottom: 5px; }
        .widget-title { font-weight: bold; margin: 0; font-size: 14px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;}
        .widget-body { flex-grow: 1; min-height: 0; position: relative;}
        .chart-container { width: 100%; height: 100%; position: absolute; top:0; left:0;}
        .btn-remove-widget { color: #dc3545; cursor: pointer; padding: 0 5px;}
    </style>
</head>
<body class="layout-fixed sidebar-expand-lg bg-body-tertiary">
    <div class="app-wrapper">
        <%- include('../../partials/header') %>
        <%- include('../../partials/sidebar') %>

        <main class="app-main">
            <div class="app-content-header">
                <div class="container-fluid">
                    <div class="row">
                        <div class="col-sm-6">
                            <h3 class="mb-0" id="dash-title"><%= dashboard ? dashboard.name : 'Untitled Dashboard' %></h3>
                            <button class="btn btn-sm btn-link p-0" id="btn-edit-title">Edit Title</button>
                        </div>
                        <div class="col-sm-6 text-end">
                            <button class="btn btn-success" id="btn-save-dash"><i class="bi bi-save"></i> Save Dashboard</button>
                        </div>
                    </div>
                </div>
            </div>
            
            <div class="app-content">
                <div class="container-fluid">
                    <div class="row">
                        <!-- Left Column: Reports List -->
                        <div class="col-md-3">
                            <div class="card mb-4 shadow-sm">
                                <div class="card-header bg-primary text-white">
                                    <h3 class="card-title mb-0"><i class="bi bi-list-ul"></i> Available Reports</h3>
                                </div>
                                <div class="card-body p-2" id="reports-list">
                                    <% if (reports && reports.length > 0) { %>
                                        <% reports.forEach(r => { %>
                                            <div class="report-draggable" data-id="<%= r.id %>" data-name="<%= r.name %>">
                                                <i class="bi bi-grip-vertical text-muted me-2"></i> <%= r.name %>
                                            </div>
                                        <% }) %>
                                    <% } else { %>
                                        <div class="text-muted text-center p-3">No reports found. Go create one first!</div>
                                    <% } %>
                                </div>
                            </div>
                        </div>

                        <!-- Right Column: Canvas -->
                        <div class="col-md-9">
                            <div class="card mb-4 shadow-sm">
                                <div class="card-header bg-light">
                                    <h3 class="card-title mb-0"><i class="bi bi-grid-3x3-gap"></i> Dashboard Canvas</h3>
                                </div>
                                <div class="card-body bg-body-secondary p-3">
                                    <div class="grid-stack"></div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </main>
        
        <!-- Footer -->
        <%- include('../../partials/footer') %>
    </div>

    <!-- Data Injection -->
    <script>
        window.DASHBOARD_DATA = <%- dashboard ? dashboard.layout_config : '[]' %>;
        window.DASHBOARD_ID = <%= dashboard ? dashboard.id : 'null' %>;
    </script>

    <!-- Scripts -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/admin-lte@4.0.0-beta2/dist/js/adminlte.min.js"></script>
    
    <!-- GridStack -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gridstack.js/9.2.2/gridstack-all.js"></script>
    <!-- ECharts -->
    <script src="https://cdn.jsdelivr.net/npm/echarts@5.5.0/dist/echarts.min.js"></script>
    
    <!-- Custom Logic -->
    <script src="/js/dashboard-builder.js"></script>
</body>
</html>

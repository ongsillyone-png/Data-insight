<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/admin-lte@4.0.0-beta2/dist/css/adminlte.min.css">
</head>
<body class="bg-body-secondary d-flex justify-content-center align-items-center" style="min-height: 100vh;">
    <div class="card shadow" style="width: 500px;" id="setup-card">
        <div class="card-header bg-dark text-white text-center">
            <h4><i class="bi bi-person-badge"></i> Setup Wizard (Step 3/3)</h4>
        </div>
        <div class="card-body">
            <h5 class="card-title text-center mb-4">Create Admin Account</h5>
            <p class="text-muted small">Create the master administrator account for Dynamic Report Builder.</p>
            
            <form id="install-form">
                <div class="mb-3">
                    <label class="form-label">Email Address</label>
                    <input type="email" id="email" class="form-control" required>
                </div>
                <div class="mb-4">
                    <label class="form-label">Password</label>
                    <input type="password" id="password" class="form-control" required minlength="6">
                </div>
                
                <div class="d-flex justify-content-between">
                    <a href="/install/step2" class="btn btn-outline-secondary">Back</a>
                    <button type="submit" class="btn btn-dark" id="btn-next">
                        Finish Setup <i class="bi bi-check-circle"></i>
                    </button>
                </div>
            </form>
        </div>
    </div>

    <!-- Success Container -->
    <div class="card shadow border-success" style="width: 500px; display: none;" id="success-card">
        <div class="card-body text-center py-5">
            <i class="bi bi-check-circle-fill text-success" style="font-size: 4rem;"></i>
            <h3 class="mt-3">Installation Complete!</h3>
            <p class="text-muted mb-4">The configuration has been written to <code>.env</code>. <br>To apply the changes, please restart the Node.js server.</p>
            <div class="alert alert-warning text-start small">
                <strong>Important:</strong> 
                <br>1. Go to your terminal running the server.
                <br>2. Press <code>Ctrl + C</code> to stop it.
                <br>3. Run <code>npm run dev</code> or <code>node app.js</code> again.
                <br>4. After starting, refresh this page or click below.
            </div>
            <a href="/login" class="btn btn-success mt-2">Go to Login Page</a>
        </div>
    </div>

    <script>
        document.getElementById('install-form').addEventListener('submit', async (e) => {
            e.preventDefault();
            const btn = document.getElementById('btn-next');
            btn.innerHTML = '<span class="spinner-border spinner-border-sm"></span> Finalizing...';
            btn.disabled = true;

            const payload = {
                email: document.getElementById('email').value,
                password: document.getElementById('password').value
            };

            try {
                const res = await fetch('/api/install/step3', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(payload)
                });
                const data = await res.json();
                
                if (res.ok) {
                    document.getElementById('setup-card').style.display = 'none';
                    document.getElementById('success-card').style.display = 'block';
                } else {
                    alert('Installation Failed: ' + data.error);
                    btn.innerHTML = 'Finish Setup <i class="bi bi-check-circle"></i>';
                    btn.disabled = false;
                }
            } catch (err) {
                alert('Error: ' + err.message);
                btn.innerHTML = 'Finish Setup <i class="bi bi-check-circle"></i>';
                btn.disabled = false;
            }
        });
    </script>
</body>
</html>

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <!-- Bootstrap 5 -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <!-- AdminLTE 4 -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/admin-lte@4.0.0-beta2/dist/css/adminlte.min.css">
</head>
<body class="layout-fixed sidebar-expand-lg bg-body-tertiary">
    <div class="app-wrapper">
        <!-- Header -->
        <%- include('../../partials/header') %>

        <!-- Sidebar -->
        <%- include('../../partials/sidebar') %>

        <!-- Main Content -->
        <main class="app-main">
            <div class="app-content-header">
                <div class="container-fluid">
                    <div class="row">
                        <div class="col-sm-6"> <h3 class="mb-0">Reports</h3> </div>
                        <div class="col-sm-6 text-end">
                            <a href="/reports/new" class="btn btn-primary"><i class="bi bi-plus-circle"></i> New Report</a>
                        </div>
                    </div>
                </div>
            </div>
            <div class="app-content">
                <div class="container-fluid">
                    <div class="row">
                        <div class="col-12">
                            <div class="card">
                                <div class="card-header"><h3 class="card-title">Saved Reports</h3></div>
                                <div class="card-body table-responsive p-0">
                                    <table class="table table-hover text-nowrap">
                                        <thead>
                                            <tr>
                                                <th>ID</th>
                                                <th>Name</th>
                                                <th>Creator</th>
                                                <th>Date</th>
                                                <th>Action</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <% if (reports && reports.length > 0) { %>
                                                <% reports.forEach(r => { %>
                                                    <tr>
                                                        <td><%= r.id %></td>
                                                        <td><%= r.name %></td>
                                                        <td><%= r.creator_email %></td>
                                                        <td><%= new Date(r.created_at).toLocaleString() %></td>
                                                        <td>
                                                            <% if (r.created_by === user.id || user.role === 'admin') { %>
                                                                <button class="btn btn-sm btn-warning" onclick="openShareModal(<%= r.id %>, <%= r.is_shareable ? 'true' : 'false' %>, '<%= r.share_uuid || '' %>')"><i class="bi bi-link-45deg"></i> Share</button>
                                                            <% } %>
                                                            <a href="/reports/<%= r.id %>/export" class="btn btn-sm btn-success" target="_blank"><i class="bi bi-file-earmark-excel"></i> Export</a>
                                                            <button class="btn btn-sm btn-info"><i class="bi bi-eye"></i> View</button>
                                                            <button class="btn btn-sm btn-danger"><i class="bi bi-trash"></i></button>
                                                        </td>
                                                    </tr>
                                                <% }) %>
                                            <% } else { %>
                                                <tr>
                                                    <td colspan="5" class="text-center">No reports found.</td>
                                                </tr>
                                            <% } %>
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </main>
        
        <!-- Footer -->
        <%- include('../../partials/footer') %>
    </div>

    <!-- Share Modal -->
    <div class="modal fade" id="shareModal" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Share Report via Link</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <input type="hidden" id="share-report-id">
                    
                    <div class="form-check form-switch mb-3">
                        <input class="form-check-input" type="checkbox" id="enable-share">
                        <label class="form-check-label" for="enable-share">Enable Password-Protected Link</label>
                    </div>

                    <div id="share-settings" style="display: none;">
                        <div class="mb-3">
                            <label class="form-label">Set / Update Password</label>
                            <input type="password" id="share-password" class="form-control" placeholder="Enter new password (optional if already set)">
                            <small class="text-muted">Leave blank to keep existing password.</small>
                        </div>
                        <div class="mb-3" id="share-link-container" style="display: none;">
                            <label class="form-label">Shared Link</label>
                            <div class="input-group">
                                <input type="text" id="share-link-url" class="form-control" readonly>
                                <button class="btn btn-outline-secondary" type="button" onclick="copyLink()"><i class="bi bi-clipboard"></i> Copy</button>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                    <button type="button" class="btn btn-primary" onclick="saveShareSettings()">Save Changes</button>
                </div>
            </div>
        </div>
    </div>

    <!-- Scripts -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/admin-lte@4.0.0-beta2/dist/js/adminlte.min.js"></script>
    <script>
        const shareModal = new bootstrap.Modal(document.getElementById('shareModal'));
        const enableShareToggle = document.getElementById('enable-share');
        const shareSettings = document.getElementById('share-settings');
        
        enableShareToggle.addEventListener('change', (e) => {
            shareSettings.style.display = e.target.checked ? 'block' : 'none';
        });

        function openShareModal(id, isShareable, uuid) {
            document.getElementById('share-report-id').value = id;
            enableShareToggle.checked = isShareable;
            shareSettings.style.display = isShareable ? 'block' : 'none';
            document.getElementById('share-password').value = '';
            
            const linkContainer = document.getElementById('share-link-container');
            const linkUrl = document.getElementById('share-link-url');
            
            if (isShareable && uuid) {
                linkContainer.style.display = 'block';
                linkUrl.value = window.location.origin + '/shared/report/' + uuid;
            } else {
                linkContainer.style.display = 'none';
                linkUrl.value = '';
            }
            
            shareModal.show();
        }

        async function saveShareSettings() {
            const id = document.getElementById('share-report-id').value;
            const isShareable = enableShareToggle.checked;
            const password = document.getElementById('share-password').value;
            
            try {
                const res = await fetch(`/api/reports/${id}/link-share`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ is_shareable: isShareable, password })
                });
                const data = await res.json();
                
                if (res.ok) {
                    alert('Sharing settings updated!');
                    window.location.reload();
                } else {
                    alert(data.error || 'Failed to update settings');
                }
            } catch (err) {
                alert('Error: ' + err.message);
            }
        }

        function copyLink() {
            const url = document.getElementById('share-link-url');
            url.select();
            document.execCommand('copy');
            alert('Link copied to clipboard!');
        }
    </script>
</body>
</html>

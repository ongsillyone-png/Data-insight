<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <!-- Bootstrap 5 -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <!-- AdminLTE 4 -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/admin-lte@4.0.0-beta2/dist/css/adminlte.min.css">
</head>
<body class="layout-fixed sidebar-expand-lg bg-body-tertiary">
    <div class="app-wrapper">
        <%- include('../../partials/header') %>
        <%- include('../../partials/sidebar') %>

        <main class="app-main">
            <div class="app-content-header">
                <div class="container-fluid">
                    <div class="row">
                        <div class="col-sm-6"> <h3 class="mb-0">Audit Logs (Query History)</h3> </div>
                    </div>
                </div>
            </div>
            <div class="app-content">
                <div class="container-fluid">
                    <div class="row">
                        <div class="col-12">
                            <div class="card">
                                <div class="card-header"><h3 class="card-title">Recent HIS Queries</h3></div>
                                <div class="card-body table-responsive p-0">
                                    <table class="table table-hover text-nowrap">
                                        <thead>
                                            <tr>
                                                <th>Time</th>
                                                <th>User</th>
                                                <th>Status</th>
                                                <th>Exec Time (ms)</th>
                                                <th>Query Snippet</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <% if (logs && logs.length > 0) { %>
                                                <% logs.forEach(log => { %>
                                                    <tr>
                                                        <td><%= new Date(log.created_at).toLocaleString() %></td>
                                                        <td><%= log.user_email || 'System' %></td>
                                                        <td>
                                                            <% if (log.status === 'success') { %>
                                                                <span class="badge bg-success">Success</span>
                                                            <% } else { %>
                                                                <span class="badge bg-danger" title="<%= log.error_message %>">Failed</span>
                                                            <% } %>
                                                        </td>
                                                        <td><%= log.execution_time_ms %></td>
                                                        <td style="max-width: 400px; overflow: hidden; text-overflow: ellipsis;">
                                                            <code><%= log.executed_sql %></code>
                                                        </td>
                                                    </tr>
                                                <% }) %>
                                            <% } else { %>
                                                <tr>
                                                    <td colspan="5" class="text-center">No logs found.</td>
                                                </tr>
                                            <% } %>
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </main>
        
        <!-- Footer -->
        <%- include('../../partials/footer') %>
    </div>
    
    <!-- Scripts -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/admin-lte@4.0.0-beta2/dist/js/adminlte.min.js"></script>
</body>
</html>
